+fn otp_algo_str_t2(a: keyroost_token2otp::Algorithm) -> &'static str {
+    match a {
+        keyroost_token2otp::Algorithm::Sha1 => "SHA1",
+        keyroost_token2otp::Algorithm::Sha256 => "SHA256",
+    }
+}
